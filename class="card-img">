<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mindmaze - The Future of Professional Skills</title>
    <style>
        :root {
            --bg-color: #050508;
            --card-bg: rgba(20, 20, 35, 0.85);
            --border-color: rgba(168, 85, 247, 0.3);
            --accent-color: #c084fc;
            --text-main: #f3f4f6;
            --text-muted: #9ca3af;
            --price-color: #4ade80;
        }
        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        header {
            text-align: center;
            margin-bottom: 40px;
            max-width: 700px;
        }
        h1 {
            color: var(--accent-color);
            font-size: 3rem;
            margin-bottom: 5px;
            letter-spacing: 2px;
        }
        p {
            color: var(--text-muted);
            font-size: 1.05rem;
        }
        .badge {
            background: linear-gradient(135deg, #1e1b4b, #311045);
            border: 1px solid var(--accent-color);
            color: var(--accent-color);
            padding: 8px 18px;
            border-radius: 30px;
            font-weight: bold;
            display: inline-block;
            margin-top: 15px;
            box-shadow: 0 4px 20px rgba(192, 132, 252, 0.15);
        }
        .container {
            width: 100%;
            max-width: 750px;
        }
        .card {
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border-color);
            margin-bottom: 25px;
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(192, 132, 252, 0.3);
            border-color: var(--accent-color);
        }
        /* Style-ka sawirka ku jira kaarka */
        .card-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-bottom: 1px solid var(--border-color);
        }
        .card-content {
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .info h3 {
            margin: 0 0 5px 0;
            color: #e879f9;
            font-size: 1.25rem;
        }
        .info p {
            margin: 0;
            color: var(--price-color);
            font-weight: 600;
            font-size: 0.95rem;
        }
        .btn-enroll {
            background: linear-gradient(135deg, #7c3aed, #c084fc);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: bold;
            text-decoration: none;
            display: inline-block;
            transition: opacity 0.2s;
        }
        .btn-enroll:hover {
            opacity: 0.9;
        }
    </style>
</head>
<body>

    <header>
        <h1>MINDMAZE</h1>
        <p>We Transcend Dimensions. The Global Ecosystem for Advanced Tech, Trading & Professional Skills.</p>
        <div class="badge">Model: 30% Platform | 70% Instructor</div>
    </header>

    <div class="container">
        <!-- Tusaalaha Kaarka 1 ee wata Sawirka iyo Google Search -->
        <div class="card">
            <img src="https://images.unsplash.com/photo-1455390582262-044cdead277a?w=600&auto=format&fit=crop&q=80" alt="Technical Writing" class="card-img">
            <div class="card-content">
                <div class="info">
                    <h3>44. Technical Writing</h3>
                    <p>Level 1 ($4) | Level 2 ($8) | Level 3 ($16)</p>
                </div>
                <a href="https://www.google.com/search?q=Technical+Writing+course" target="_blank" class="btn-enroll">Join</a>
            </div>
        </div>

        <!-- Tusaalaha Kaarka 2 ee wata Sawirka iyo Google Search -->
        <div class="card">
            <img src="https://images.unsplash.com/photo-1434030216411-0b793f4b4173?w=600&auto=format&fit=crop&q=80" alt="Translation & Localization" class="card-img">
            <div class="card-content">
                <div class="info">
                    <h3>45. Translation & Localization</h3>
                    <p>Level 1 ($3) | Level 2 ($6) | Level 3 ($12)</p>
                </div>
                <a href="https://www.google.com/search?q=Translation+and+Localization" target="_blank" class="btn-enroll">Join</a>
            </div>
        </div>
    </div>

</body>
</html>
